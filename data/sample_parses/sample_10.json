    "title": "Smoked Fish Potato Salad Recipe",
    "source_ingredients": [
      "sauce, fish, ready-to-serve",
      "potatoes, raw, skin",
      "celery, raw",
      "pickles, cucumber, sour",
      "olives, ripe, canned (small-extra large)",
